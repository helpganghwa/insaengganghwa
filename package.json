{
  "name": "insaengganghwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5174",
    "build": "bun run scripts/build-sprite-atlas.ts && bun run scripts/build-asset-versions.ts && next build",
    "build:atlas": "bun run scripts/build-sprite-atlas.ts",
    "build:asset-versions": "bun run scripts/build-asset-versions.ts",
    "start": "next start -p 5174",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:apply": "bun run scripts/apply-migration.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:catalog": "bun run scripts/seed-catalog.ts",
    "verify:sprites": "bun run scripts/check-sprites.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "^0.45.2",
    "es-hangul": "^2.3.8",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
