{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": [
    "icn1"
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/payment-recon",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/mail-expire",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/push-enhance-ready",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/settle-raid",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/push-flush",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/push-daily-supply",
      "schedule": "5,35 15-23 * * *"
    },
    {
      "path": "/api/cron/profile-poll",
      "schedule": "1-59/2 * * * *"
    },
    {
      "path": "/api/cron/warm",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/melee-run",
      "schedule": "*/5 0 * * *"
    },
    {
      "path": "/api/cron/melee-reveal",
      "schedule": "*/5 1 * * *"
    },
    {
      "path": "/api/cron/conquest-run",
      "schedule": "*/5 14 * * *"
    },
    {
      "path": "/api/cron/conquest-chronicle",
      "schedule": "0-55/5 15 * * *"
    },
    {
      "path": "/api/cron/guild-rank-achv",
      "schedule": "40 15 * * *"
    },
    {
      "path": "/api/cron/rank-leader",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/cron/leaderboard-snapshot",
      "schedule": "11 * * * *"
    },
    {
      "path": "/api/cron/guild-leader-handover",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/guild-emblem-retry",
      "schedule": "3-53/10 * * * *"
    },
    {
      "path": "/api/cron/nickname-reclaim",
      "schedule": "30 19 * * *"
    },
    {
      "path": "/api/cron/daily-stats",
      "schedule": "1 15 * * *"
    },
    {
      "path": "/api/cron/scheduled-mail",
      "schedule": "2-57/5 * * * *"
    }
  ]
}